# Supabase project URL (Project Settings -> API -> Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Project Settings -> API -> service_role secret)
# Server-only. Never expose this to the client or commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key (console.anthropic.com -> Settings -> API Keys)
# Server-only, used by Stage 5 (src/lib/narrative) to generate variance
# narratives. Never expose this to the client or commit the real value.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override the narrative model (defaults to claude-haiku-4-5-20251001
# in src/lib/narrative/constants.ts if unset).
# ANTHROPIC_NARRATIVE_MODEL=claude-haiku-4-5-20251001
